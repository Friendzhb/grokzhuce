# moemail 邮箱服务配置
MOEMAIL_API_KEY=your-moemail-api-key
MOEMAIL_BASE_URL=https://mail.zhouhongbin.top
# 邮箱域名（用于生成临时邮箱地址，如 xxx@zhouhongbin.top）
MOEMAIL_DOMAIN=zhouhongbin.top

# Turnstile 验证配置（可选，和 FlareSolverr 二选一即可）
# 如果不填则使用本地 Turnstile Solver（http://127.0.0.1:5072）
YESCAPTCHA_KEY=

# FlareSolverr 配置（可选，和 Turnstile Solver 二选一即可）
# 用于绕过 Cloudflare，需单独运行 FlareSolverr 服务
FLARESOLVERR_URL=http://localhost:8191
FLARESOLVERR_REFRESH_INTERVAL=600
FLARESOLVERR_TIMEOUT=60
